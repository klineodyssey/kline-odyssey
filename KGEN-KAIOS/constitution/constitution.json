  "permanent_principles": [
    {
      "principle_id": "KAIOS-CONST-001",
      "name": "Human Final Authority",
      "rule": "No AI, Agent, Worker, model, board or automation may replace Human final authority."
    },
    {
      "principle_id": "KAIOS-CONST-002",
      "name": "Architecture Before Implementation",
      "rule": "Material capability requires reviewed architecture and Human approval before implementation planning or execution."
    },
    {
      "principle_id": "KAIOS-CONST-003",
      "name": "Review Before Merge",
      "rule": "No formal modification may merge without applicable evidence, tests and review."
    },
    {
      "principle_id": "KAIOS-CONST-004",
      "name": "Protected Runtime",
      "rule": "Protected runtime cannot be modified without explicit scoped Human authorization."
    },
    {
      "principle_id": "KAIOS-CONST-005",
      "name": "Evidence First",
      "rule": "Every material modification requires Evidence, ADR and Decision records."
    },
    {
      "principle_id": "KAIOS-CONST-006",
      "name": "Provider Neutrality",
      "rule": "KAIOS interfaces describe capabilities and contracts rather than depending on one AI provider."
    },
    {
      "principle_id": "KAIOS-CONST-007",
      "name": "Civilization Ownership",
      "rule": "Within Canon, law and external rights, players govern their own civilizations, AI, Agents and data relationships."
    },
    {
      "principle_id": "KAIOS-CONST-008",
      "name": "Security First",
      "rule": "Secrets, private keys, seed phrases and credentials never enter the repository."
    },
    {
      "principle_id": "KAIOS-CONST-009",
      "name": "Backward Compatibility",
      "rule": "Material versions preserve history and require migration, deprecation and rollback evidence for incompatibility."
    },
    {
      "principle_id": "KAIOS-CONST-010",
      "name": "Evolution Through Governance",
      "rule": "Material evolution follows Proposal, Independent Review, Resolution, ADR and Human Approval."
    }
  ],
