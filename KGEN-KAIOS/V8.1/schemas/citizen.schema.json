{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V8.1/schemas/citizen.schema.json",
  "title": "KAIOS V8.1 Citizen",
  "type": "object",
  "additionalProperties": false,
  "required": ["citizen_id", "citizen_name", "age", "race", "faction", "residence", "profession", "inventory", "wallet", "temple", "health", "energy", "skill", "experience", "level", "job", "employer", "business", "tax", "reputation", "dna", "ai_link", "app_link", "status"],
  "properties": {
    "citizen_id": { "type": "string", "pattern": "^KGEN-CIT-[A-Z0-9-]+$" },
    "citizen_name": { "type": "string", "minLength": 1 },
    "age": { "type": "integer", "minimum": 0 },
    "race": { "type": "string" },
    "faction": { "type": "string" },
    "residence": { "type": "string" },
    "profession": { "type": "string" },
    "inventory": { "type": "array", "items": { "type": "string" } },
    "wallet": { "type": "object", "required": ["wallet_id", "type"], "properties": { "wallet_id": { "type": "string" }, "type": { "type": "string" }, "chain": { "type": "string" }, "address_reference": { "type": "string" } }, "additionalProperties": false },
    "temple": { "type": "string" },
    "health": { "type": "object", "required": ["current", "max"], "properties": { "current": { "type": "number" }, "max": { "type": "number" } }, "additionalProperties": false },
    "energy": { "type": "object", "required": ["current", "max"], "properties": { "current": { "type": "number" }, "max": { "type": "number" } }, "additionalProperties": false },
    "skill": { "type": "object", "additionalProperties": { "type": "number" } },
    "experience": { "type": "integer", "minimum": 0 },
    "level": { "type": "integer", "minimum": 1 },
    "job": { "type": "string" },
    "employer": { "type": "string" },
    "business": { "type": "string" },
    "tax": { "type": "object", "properties": { "model": { "type": "string" }, "rate": { "type": "number", "minimum": 0 } }, "additionalProperties": false },
    "reputation": { "type": "number" },
    "dna": { "type": "string" },
    "ai_link": { "type": "string" },
    "app_link": { "type": "string" },
    "status": { "enum": ["Draft", "Prototype", "Active", "Dormant", "Locked", "Retired", "Archived", "Deleted", "Disputed"] }
  }
}