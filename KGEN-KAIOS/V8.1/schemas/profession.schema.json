{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V8.1/schemas/profession.schema.json",
  "title": "KAIOS V8.1 Profession",
  "type": "object",
  "additionalProperties": false,
  "required": ["profession_id", "name", "income_model", "skills", "required_building", "upgrade_path", "ai_capability", "economic_output", "status"],
  "properties": {
    "profession_id": { "type": "string", "pattern": "^KGEN-PRO-[A-Z0-9-]+$" },
    "name": { "type": "string" },
    "income_model": { "type": "array", "items": { "type": "string" } },
    "skills": { "type": "array", "items": { "type": "string" } },
    "required_building": { "type": "array", "items": { "type": "string" } },
    "upgrade_path": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "ai_capability": { "type": "array", "items": { "type": "string" } },
    "economic_output": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["Draft", "Prototype", "Active", "Retired", "Archived"] }
  }
}