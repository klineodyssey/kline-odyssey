{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.3/schemas/dispatch_risk_gate.schema.json",
  "title": "KAIOS V9.3 Dispatch Risk Gate",
  "type": "object",
  "required": ["risk_gate_id", "workorder_id", "risk_level", "human_review_required", "codex_review_required", "result"],
  "properties": {
    "risk_gate_id": { "type": "string" },
    "workorder_id": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "human_review_required": { "type": "boolean" },
    "codex_review_required": { "type": "boolean" },
    "result": { "type": "string", "enum": ["RELEASE_ALLOWED", "HUMAN_REVIEW_REQUIRED", "RELEASE_PROHIBITED"] }
  },
  "additionalProperties": false
}
