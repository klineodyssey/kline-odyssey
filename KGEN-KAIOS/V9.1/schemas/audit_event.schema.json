{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.1/schemas/audit_event.schema.json",
  "title": "KAIOS V9.1 Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "timestamp",
    "actor",
    "actor_role",
    "related_decision_id",
    "related_workorder_id",
    "previous_status",
    "new_status",
    "risk_level",
    "decision",
    "reason",
    "evidence",
    "requires_human_review",
    "requires_codex_review"
  ],
  "properties": {
    "audit_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "actor_role": { "type": "string", "enum": ["AI", "Codex", "Human", "Worker", "System"] },
    "related_decision_id": { "type": "string" },
    "related_workorder_id": { "type": "string" },
    "previous_status": { "type": "string" },
    "new_status": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "decision": { "type": "string" },
    "reason": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "requires_human_review": { "type": "boolean" },
    "requires_codex_review": { "type": "boolean" }
  }
}
