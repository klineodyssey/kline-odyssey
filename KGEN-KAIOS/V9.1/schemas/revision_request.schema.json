{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.1/schemas/revision_request.schema.json",
  "title": "KAIOS V9.1 Revision Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "revision_id",
    "task_id",
    "requested_by",
    "timestamp",
    "reason",
    "required_changes",
    "risk_level",
    "due_status"
  ],
  "properties": {
    "revision_id": { "type": "string" },
    "task_id": { "type": "string" },
    "requested_by": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "reason": { "type": "string" },
    "required_changes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "risk_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "due_status": { "type": "string", "enum": ["REVISED_DRAFT", "BLOCKED"] }
  }
}
