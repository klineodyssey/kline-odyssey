{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.1/schemas/human_review.schema.json",
  "title": "KAIOS V9.1 Human Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "reviewer",
    "timestamp",
    "decision",
    "reason",
    "previous_status",
    "new_status",
    "risk_level",
    "related_decision_id",
    "related_workorder_id"
  ],
  "properties": {
    "review_id": { "type": "string" },
    "reviewer": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "decision": { "type": "string", "enum": ["APPROVE", "REJECT", "PAUSE", "CHANGE_PRIORITY", "BLOCK", "ARCHIVE"] },
    "reason": { "type": "string" },
    "previous_status": { "type": "string" },
    "new_status": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "related_decision_id": { "type": "string" },
    "related_workorder_id": { "type": "string" }
  }
}
