{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.1/schemas/draft_workorder.schema.json",
  "title": "KAIOS V9.1 Draft WorkOrder",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "decision_id",
    "reason",
    "priority",
    "risk_level",
    "dependencies",
    "input_state",
    "expected_output",
    "acceptance_criteria",
    "protected_paths",
    "owner_suggestion",
    "reviewer",
    "branch_pattern",
    "report_path",
    "legal_review_required",
    "security_review_required",
    "human_review_required",
    "codex_review_required",
    "status"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 3 },
    "decision_id": { "type": "string", "minLength": 3 },
    "reason": { "type": "string", "minLength": 10 },
    "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4"] },
    "risk_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "input_state": { "type": "array", "items": { "type": "string" } },
    "expected_output": { "type": "string", "minLength": 10 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "protected_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "owner_suggestion": { "type": "string", "minLength": 3 },
    "reviewer": { "type": "string", "minLength": 3 },
    "branch_pattern": { "type": "string", "pattern": "^cursor-handoff/.+" },
    "report_path": { "type": "string", "pattern": "^KGEN-KAIOS/.+" },
    "legal_review_required": { "type": "boolean" },
    "security_review_required": { "type": "boolean" },
    "human_review_required": { "type": "boolean" },
    "codex_review_required": { "type": "boolean" },
    "status": { "type": "string", "enum": ["DRAFT"] }
  }
}
