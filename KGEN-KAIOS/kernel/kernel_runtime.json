  "states": [
    {
      "state": "BOOT",
      "purpose": "Validate identity, policy, workspace, health and memory sources.",
      "allows_execution": false
    },
    {
      "state": "READY",
      "purpose": "Wait for one valid assigned mission.",
      "allows_execution": false
    },
    {
      "state": "WORKING",
      "purpose": "Execute actions permitted by the active mission.",
      "allows_execution": true
    },
    {
      "state": "WAITING",
      "purpose": "Pause for input, dependency, decision or recoverable resource.",
      "allows_execution": false
    },
    {
      "state": "REVIEW",
      "purpose": "Submit evidence to an independent reviewer.",
      "allows_execution": false
    },
    {
      "state": "REWARD",
      "purpose": "Record an approved prototype reward event.",
      "allows_execution": false
    },
    {
      "state": "SLEEP",
      "purpose": "Checkpoint memory, release claims and close the workday.",
      "allows_execution": false
    },
    {
      "state": "OFFLINE",
      "purpose": "Hold no active mission, tools or execution authority.",
      "allows_execution": false
    }
