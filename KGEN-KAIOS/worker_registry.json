  "trust_levels": {
    "T0": "Unregistered: cannot work",
    "T1": "Onboarding: dry run / sandbox / documentation only, 100% review",
    "T2": "Active: ordinary WorkOrders, 100% review",
    "T3": "Trusted: more concurrent low-risk work, fast review possible for R0/R1",
