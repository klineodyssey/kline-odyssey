{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/workforce/WORKER_CREDENTIAL_SCHEMA.json",
  "title": "KGEN Worker Credential",
  "type": "object",
  "required": [
    "worker_id",
    "worker_status",
    "trust_level",
    "boot_acknowledged",
    "canon_acknowledged",
    "workspace_policy_acknowledged",
    "do_not_touch_acknowledged",
    "claim_id",
    "task_id",
    "base_commit",
    "branch",
    "lease_expires_at"
  ],
  "properties": {
    "worker_id": { "type": "string" },
    "worker_status": {
      "type": "string",
      "enum": [
        "PENDING_REGISTRATION",
        "ONBOARDING",
        "ACTIVE",
        "PROBATION",
        "TRUSTED",
        "SENIOR_TRUSTED",
        "SUSPENDED",
        "REVOKED",
        "ARCHIVED"
      ]
    },
    "trust_level": { "type": "string", "enum": ["T0", "T1", "T2", "T3", "T4", "T5"] },
    "boot_acknowledged": { "type": "boolean" },
    "canon_acknowledged": { "type": "boolean" },
    "workspace_policy_acknowledged": { "type": "boolean" },
    "do_not_touch_acknowledged": { "type": "boolean" },
    "claim_id": { "type": "string" },
    "task_id": { "type": "string" },
    "base_commit": { "type": "string" },
    "branch": { "type": "string" },
    "lease_expires_at": { "type": "string", "format": "date-time" },
    "issued_at": { "type": "string", "format": "date-time" },
    "reviewer": { "type": "string" }
  },
  "additionalProperties": false
}

