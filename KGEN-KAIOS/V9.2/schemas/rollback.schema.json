{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V9.2/schemas/rollback.schema.json",
  "title": "KAIOS V9.2 Rollback",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rollback_id",
    "reason",
    "previous_status",
    "new_status",
    "affected_workorder",
    "reviewer",
    "timestamp",
    "related_commit"
  ],
  "properties": {
    "rollback_id": { "type": "string" },
    "reason": { "type": "string" },
    "previous_status": { "type": "string", "enum": ["OPEN"] },
    "new_status": { "type": "string", "enum": ["APPROVED_FOR_OPEN"] },
    "affected_workorder": { "type": "string" },
    "reviewer": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "related_commit": { "type": "string" }
  }
}
