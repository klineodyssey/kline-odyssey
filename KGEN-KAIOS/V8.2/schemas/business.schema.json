{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klineodyssey.github.io/kline-odyssey/KGEN-KAIOS/V8.2/schemas/business.schema.json",
  "title": "KAIOS V8.2 Business",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_id",
    "business_type",
    "owner",
    "employees",
    "required_profession",
    "required_building",
    "production",
    "consumption",
    "inventory",
    "revenue",
    "expense",
    "growth",
    "level",
    "upgrade_path",
    "status"
  ],
  "properties": {
    "business_id": { "type": "string", "pattern": "^KGEN-BUS-[A-Z0-9-]+$" },
    "business_type": {
      "enum": [
        "Temple",
        "Farm",
        "Mine",
        "Factory",
        "Restaurant",
        "Clothing Store",
        "Weapon Shop",
        "Potion Shop",
        "Book Store",
        "Hospital",
        "School",
        "Hotel",
        "Museum",
        "Convenience Store",
        "Shopping Mall",
        "Logistics Center",
        "Warehouse",
        "Energy Station",
        "Data Center",
        "AI Center",
        "Marketplace",
        "Bank",
        "Exchange"
      ]
    },
    "owner": { "type": "string" },
    "employees": { "type": "array", "items": { "type": "string" } },
    "required_profession": { "type": "array", "items": { "type": "string" } },
    "required_building": { "type": "array", "items": { "type": "string" } },
    "production": { "type": "array", "items": { "type": "string" } },
    "consumption": { "type": "array", "items": { "type": "string" } },
    "inventory": { "type": "object", "additionalProperties": { "type": "number", "minimum": 0 } },
    "revenue": { "type": "number", "minimum": 0 },
    "expense": { "type": "number", "minimum": 0 },
    "growth": { "type": "number", "minimum": 0 },
    "level": { "type": "integer", "minimum": 1 },
    "upgrade_path": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["Concept", "Prototype", "Simulation", "Production", "Regulated", "Archived"] }
  }
}
