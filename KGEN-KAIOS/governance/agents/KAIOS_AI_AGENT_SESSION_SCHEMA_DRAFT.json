{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "KAIOS_AI_AGENT_SESSION_SCHEMA_DRAFT",
  "title": "KAIOS AI Agent Session Schema Draft",
  "status": "READY_FOR_BASELINE_REVIEW",
  "implementation_status": "NOT_STARTED",
  "description": "Draft schema for durable AI Life records, per-session Agent Instance records, handoffs, repository messages, performance records and incidents. Includes narrow baseline repair contracts for attestation, birth records, capability grants, revocation, locks, stale blocking, current pointer, evidence provenance and secret boundaries.",
