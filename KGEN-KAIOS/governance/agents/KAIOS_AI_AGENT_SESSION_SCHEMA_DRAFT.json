  "required": [
    "life_record",
    "session_record",
    "handoff_record",
    "message_record",
    "performance_record",
    "incident_record",
    "agent_identity_attestation",
    "session_birth_record",
    "capability_grant",
    "capability_revocation",
    "session_lock",
    "canonical_current_state_pointer",
    "evidence_provenance",
    "secret_access_record"
  ],
