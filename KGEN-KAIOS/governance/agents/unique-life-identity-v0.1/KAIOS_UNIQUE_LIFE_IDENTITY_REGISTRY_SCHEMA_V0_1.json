          "type": "string",
          "pattern": "^COMPOSITE-V01-[A-Z0-9]{3,16}-[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "id_metadata": { "$ref": "#/$defs/identifier_metadata" },
        "member_life_ids": {
          "type": "array",
          "minItems": 2,
