        "expires_at": { "$ref": "#/$defs/timestamp" },
        "issued_by": { "type": "string" },
        "signer_evidence_ref": { "type": "string" },
        "revocation_status": {
          "enum": ["ACTIVE", "REVOKED", "EXPIRED", "SUPERSEDED"]
