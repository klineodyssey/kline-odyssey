          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "ownership_shares": { "type": "object" },
        "occupancy_rules": { "type": "object" },
        "authority_rules": { "type": "object" },
