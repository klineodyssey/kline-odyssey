        "liability_scope_refs": { "type": "array", "items": { "type": "string" } },
        "excluded_wallet_ids": { "type": "array", "items": { "type": "string" } },
        "excluded_memory_store_ids": { "type": "array", "items": { "type": "string" } },
        "governing_authority_ref": { "type": "string" },
