  "laws": [
    { "law_id": "WL-01", "name": "UNIVERSAL_LIFE_REGISTRATION", "rule": "All approved KAIOS entity classes may receive a governed LifeIdentity." },
    { "law_id": "WL-02", "name": "LIFE_IDENTITY_AND_CONTINUITY", "rule": "Every life has unique identity, continuity, energy, lifecycle, class and timeline data; DNA is conditional." },
    { "law_id": "WL-03", "name": "ENERGY_DEPENDENCY", "rule": "Every active life consumes conserved profile-specific energy or resources." },
    { "law_id": "WL-04", "name": "FOOD_AND_NUTRITION", "rule": "Food is modeled as a provenance-bearing Species-compatible food web." },
    { "law_id": "WL-05", "name": "CIVILIZATION_BOOTSTRAP", "rule": "Spawn requires a viable pre-existing civilization context and capacity." },
    { "law_id": "WL-06", "name": "PLAYER_SPAWN", "rule": "Every spawn has an approved origin and no player appears without provenance." },
    { "law_id": "WL-07", "name": "DEATH_NOT_DELETION", "rule": "Death seals identity state and preserves history; it does not delete records." },
    { "law_id": "WL-08", "name": "REINCARNATION_GOVERNED_TECHNOLOGY", "rule": "Reincarnation is reviewed simulation technology that creates a new Life ID." },
    { "law_id": "WL-09", "name": "CURRENT_TIMELINE_FIRST", "rule": "Initial existence is in Current Timeline and travel is technology and permission gated." },
    { "law_id": "WL-10", "name": "INTELLIGENCE_TIERS", "rule": "Tier 0 through Tier 8 classify capability but grant no authority or rights." },
    { "law_id": "WL-11", "name": "TEMPLE_HOUSE_LAND_BUILDING_ORGANISMS", "rule": "Physical domain entities use Life adapters without losing domain authority boundaries." },
    { "law_id": "WL-12", "name": "COMPANY_ORGANISMS", "rule": "Organizations may have governed life identity and lifecycle without Life OS owning company operations." },
    { "law_id": "WL-13", "name": "CONSENT_GOVERNED_FAMILY", "rule": "Real-player family relationships require all required participant confirmations." },
    { "law_id": "WL-14", "name": "BLOODLINE_AND_FAMILY_PERSISTENCE", "rule": "Lineage survives individual death but grants no automatic privilege." },
    { "law_id": "WL-15", "name": "HOUSE_ORGANISM", "rule": "House identity is distinct from parcel, owner, tenant and family identities." },
    { "law_id": "WL-16", "name": "TEMPLE_ORGANISM", "rule": "Temple creation needs specification, land right, manufacturing, integrity and registry approval." },
    { "law_id": "WL-17", "name": "COMPANY_LIFECYCLE", "rule": "Company viability is projected to Life OS while operations remain in Company Runtime." },
    { "law_id": "WL-18", "name": "NPC_INTEGRITY", "rule": "NPCs have governed identity, needs, permissions and lifecycle and cannot impersonate real people." },
    { "law_id": "WL-19", "name": "LIFE_CYCLE", "rule": "Every Species or class defines versioned evidence-bearing lifecycle transitions." },
    { "law_id": "WL-20", "name": "SPECIES_SPECIFIC_ENERGY", "rule": "Energy conversion, loss, waste and failure thresholds are profile specific." },
    { "law_id": "WL-21", "name": "LIVING_CIVILIZATION_AT_LOGIN", "rule": "Pre-existing world services require real snapshot, capacity and resource-flow state." },
    { "law_id": "WL-22", "name": "PROFESSION", "rule": "Profession belongs to Citizen Runtime and is capability, age, education, evidence and consent gated." },
    { "law_id": "WL-23", "name": "EVERYTHING_HAS_LIFE", "rule": "Universal life identity preserves capability and domain distinctions and does not make every entity a Citizen." }
  ],
